# Optional but recommended: a free Hugging Face token improves your
# priority in the shared ZeroGPU queue. Get one (no card) at
# https://huggingface.co/settings/tokens -- leave blank to try anonymously.
HF_TOKEN=

# Required for color analysis + sustainability research (Claude API calls).
ANTHROPIC_API_KEY=

# Optional: if set, server/tryonCore.js's fallback path will be exercised
# when the free HF Space try-on call fails/times out. Not implemented for
# the hackathon build (no `replicate` package wired up yet) -- leave blank
# to keep current behavior (HF errors are simply surfaced as-is).
# REPLICATE_API_TOKEN=

PORT=3000
